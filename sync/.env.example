# Endpoint del bot deployado en Railway (sin trailing slash)
INBOXZERO_API_URL=https://tu-bot.up.railway.app

# Misma SYNC_API_KEY que tenés en el bot
INBOXZERO_API_KEY=

# Path absoluto al vault de Obsidian
OBSIDIAN_VAULT_PATH=/Users/roldanjorgex/second-brain

# Carpeta dentro del vault donde escribir las capturas (relativa al vault).
# Default: el inbox principal del vault, sin subcarpeta.
INBOXZERO_SUBDIR=_Inbox

# Carpeta para recordatorios. Default: misma carpeta que las capturas.
INBOXZERO_REMINDERS_SUBDIR=_Inbox

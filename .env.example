# =========================
#   v1 — obligatorio
# =========================

# Token del bot de Telegram (de @BotFather). NO commitear el real.
TELEGRAM_BOT_TOKEN=<pegar-token-de-BotFather-aca>

# IDs de Telegram autorizados (separados por coma). Solo estos pueden mandar mensajes.
# Para encontrar tu user_id: hablale a @userinfobot en Telegram.
ALLOWED_USER_IDS=

# API key para los endpoints HTTP de sync. Generala con `openssl rand -hex 32`.
SYNC_API_KEY=cambiar-por-token-largo-aleatorio

# Path absoluto a la base SQLite. En Railway, usar /data si tenés volumen montado.
DB_PATH=/data/inboxzero.db

# Puerto que Railway inyecta automáticamente. No tocar.
PORT=8000


# =========================
#   v2 — opcionales
# =========================

# --- Clasificación con Claude (opcional). Si está vacío, usa heurística. ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Digest diario (opcional). ---
# Si DIGEST_ENABLED=true, el bot manda un resumen cada día a DIGEST_HOUR:DIGEST_MINUTE
# en la zona horaria DIGEST_TZ, al chat DIGEST_CHAT_ID (típicamente el chat privado contigo).
DIGEST_ENABLED=false
DIGEST_HOUR=8
DIGEST_MINUTE=0
DIGEST_TZ=America/Argentina/Buenos_Aires
DIGEST_CHAT_ID=

# --- Web UI (read+edit). Default: habilitada. ---
WEB_UI_ENABLED=true

# --- Transcripción local de audios (Whisper). ---
# Si está habilitado, los mensajes de voz/audio se transcriben con Whisper local
# (sin API externa) y se guardan como capturas tipo 'idea'.
WHISPER_ENABLED=true

# Modelo: tiny (39MB) | base (74MB, default) | small (244MB) | medium (769MB) | large (1.5GB).
# Cambiar requiere rebuild del container con --build-arg WHISPER_MODEL=small
WHISPER_MODEL=base

# Idioma forzado para mejor calidad (ISO 639-1). Vacío = autodetect.
WHISPER_LANGUAGE=es
